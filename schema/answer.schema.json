{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://research-compiler/schema/answer.schema.json",
  "title": "Answer",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "id", "stream", "text", "status", "answers", "backed_by", "edge_comments", "provenance", "comments"],
  "properties": {
    "type": { "const": "answer" },
    "id": { "type": "string", "pattern": "^a-[0-9]{4,}$" },
    "stream": { "type": "string" },
    "text": { "type": "string" },
    "status": { "enum": ["proposed", "supported", "refuted", "inconclusive"] },
    "answers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^q-[0-9]{4,}$" }
    },
    "backed_by": {
      "type": "array",
      "items": { "type": "string", "pattern": "^e-[0-9]{4,}$" }
    },
    "edge_comments": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "provenance": { "$ref": "https://research-compiler/schema/provenance.schema.json" },
    "comments": { "type": "object", "additionalProperties": { "type": "string" } },
    "report": { "type": "string" },
    "stories": { "type": "array", "items": { "type": "string" } },
    "objects": { "type": "array", "items": { "type": "string", "pattern": "^o-[0-9]{4,}$" } },
    "supersedes": { "type": "array", "items": { "type": "string", "pattern": "^a-[0-9]{4,}$" } },
    "bibliography": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "relevance": { "type": "string" }
        }
      }
    }
  }
}
