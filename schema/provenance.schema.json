{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://research-compiler/schema/provenance.schema.json",
  "title": "Provenance",
  "type": "object",
  "additionalProperties": false,
  "required": ["created_by", "created_at", "updated_at"],
  "properties": {
    "created_by": { "enum": ["human", "claude"] },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo"],
      "properties": {
        "repo": { "type": "string" },
        "commit": { "type": "string" },
        "note": { "type": "string" }
      }
    }
  }
}
